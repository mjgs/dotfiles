# variable exports
source $HOME/.exports

# aliases
source $HOME/.aliases

# functions
source $HOME/.functions

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"  # This loads nvm

# local zsh configuration
if [ -f $HOME/.bashrc_local ]; then 
  source $HOME/.bashrc_local
fi
