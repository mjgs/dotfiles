# variable exports
source $HOME/.exports

# aliases
source $HOME/.aliases

# functions
source $HOME/.functions

# oh-my-zsh
source $HOME/.oh-my-zshrc

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"  # This loads nvm

# local zsh configuration
source $HOME/.zshrc_local
