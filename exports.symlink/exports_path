# Basic PATH setup (read from left to right by the shell)
export PATH="/usr/bin:/bin:/usr/sbin:/sbin"

# Add brew executables (take precendence)
export PATH="/usr/local/bin:/usr/local/sbin:$PATH"

# Add dotfiles executables
export PATH="$DOTFILES_DIR/bin:$PATH"

# Add specific application executables
export PATH="/usr/local/opt/mongodb-community@4.0/bin:$PATH"
export PATH="/usr/local/opt/openssl/bin:$PATH"

# Add languages to PATH
export PATH="$LANGUAGES_DIR/perl/versions/perl-$LANGUAGES_PERL_VERSION/bin:$PATH"
export PATH="$LANGUAGES_DIR/ruby/versions/ruby-$LANGUAGES_RUBY_VERSION/bin:$PATH"
export PATH="$LANGUAGES_DIR/node/versions/node-v$LANGUAGES_NODE_VERSION/bin:$PATH"
